---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="hr">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body>
		<Header />
		<main class="article-main">
			<article>
				<header class="article-header">
					<a href="/blog" class="back-link">
						<span aria-hidden="true">←</span> Svi zapisi
					</a>

					<p class="article-meta">
						<FormattedDate date={pubDate} />
						{
							updatedDate && (
								<>
									<span class="meta-dot" aria-hidden="true" />
									<span class="updated">
										Ažurirano <FormattedDate date={updatedDate} />
									</span>
								</>
							)
						}
					</p>

					<h1>{title}</h1>
					{description && <p class="article-lede">{description}</p>}
				</header>

				{
					heroImage && (
						<figure class="hero-image">
							<Image
								src={heroImage}
								alt=""
								width={1440}
								sizes="(min-width: 720px) 720px, 100vw"
								priority
							/>
						</figure>
					)
				}

				<div class="prose">
					<slot />
				</div>

				<footer class="article-footer">
					<a href="/blog" class="back-link">
						<span aria-hidden="true">←</span> Natrag na sve zapise
					</a>
				</footer>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	.article-main {
		max-width: 720px;
		padding-top: clamp(2.5rem, 6vw, 4rem);
	}

	.article-header {
		margin: 0;
		padding: 0 0 2.5rem;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		margin-bottom: 2rem;
		font-family: var(--font-mono);
		font-size: 0.74rem;
		letter-spacing: 0.04em;
		color: var(--color-muted);
		text-decoration: none;
		transition: color 160ms ease;
	}
	.back-link:hover {
		color: var(--color-ink);
	}

	.article-meta {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.7rem;
		font-family: var(--font-mono);
		font-size: 0.74rem;
		letter-spacing: 0.02em;
		color: var(--color-muted);
		margin: 0 0 1.25rem;
	}
	.meta-dot {
		width: 3px;
		height: 3px;
		border-radius: 50%;
		background: var(--color-rule-strong);
	}
	.updated {
		font-style: italic;
	}

	.article-header h1 {
		margin: 0 0 1rem;
	}
	.article-lede {
		font-family: var(--font-serif);
		font-size: clamp(1.15rem, 2vw, 1.35rem);
		font-weight: 400;
		line-height: 1.5;
		letter-spacing: -0.01em;
		color: var(--color-muted);
		margin: 0;
		max-width: 60ch;
	}

	.hero-image {
		margin: 0 0 3rem;
		padding: 0;
	}
	.hero-image :global(img) {
		display: block;
		width: 100%;
		height: auto;
		max-height: 540px;
		object-fit: cover;
		border-radius: 4px;
		border: 1px solid var(--color-rule);
	}

	.prose {
		max-width: 65ch;
		color: var(--color-ink-soft);
	}

	.article-footer {
		margin: 4rem 0 0;
		padding-top: 2rem;
		border-top: 1px solid var(--color-rule);
	}

	@media (max-width: 720px) {
		.article-header {
			padding-bottom: 1.75rem;
		}
		.article-lede {
			font-size: 1.1rem;
		}
		.hero-image {
			margin-bottom: 2rem;
		}
	}
</style>
