---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="hr">
	<head>
		<BaseHead title={`Zapisi — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<header class="page-head">
				<p class="eyebrow">Arhiva</p>
				<h1>Zapisi s terena</h1>
				<p class="lede">
					{posts.length} {posts.length === 1 ? 'zapis' : 'zapisa'}, poredano od najnovijih.
					Dnevnik ekspedicije po Istri.
				</p>
			</header>

			<ol class="post-list" role="list">
				{
					posts.map((post) => (
						<li class="post-row">
							<a href={`/blog/${post.id}/`}>
								<span class="row-date">
									<FormattedDate date={post.data.pubDate} />
								</span>
								<span class="row-body">
									<span class="row-title">{post.data.title}</span>
									<span class="row-desc">{post.data.description}</span>
								</span>
								<span class="row-arrow" aria-hidden="true">→</span>
							</a>
						</li>
					))
				}
			</ol>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-head {
		max-width: 60ch;
		padding: clamp(2rem, 6vw, 4rem) 0 clamp(3rem, 6vw, 4rem);
	}
	.page-head h1 {
		margin: 1rem 0 1.25rem;
	}
	.lede {
		color: var(--color-muted);
		font-size: 1.0625rem;
		line-height: 1.6;
		margin: 0;
	}

	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		border-top: 1px solid var(--color-rule);
	}
	.post-row {
		margin: 0;
		border-bottom: 1px solid var(--color-rule);
	}
	.post-row a {
		display: grid;
		grid-template-columns: 130px 1fr auto;
		align-items: baseline;
		gap: 1.5rem;
		padding: 1.5rem 0.25rem;
		text-decoration: none;
		color: var(--color-ink);
		transition: padding 200ms cubic-bezier(0.16, 1, 0.3, 1);
	}
	.post-row a:hover {
		padding-left: 0.85rem;
	}
	.post-row a:hover .row-arrow {
		transform: translateX(3px);
		color: var(--color-ink);
	}
	.row-date {
		font-family: var(--font-mono);
		font-size: 0.74rem;
		color: var(--color-muted);
		letter-spacing: 0.02em;
	}
	.row-body {
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
		min-width: 0;
	}
	.row-title {
		font-size: 1.0625rem;
		font-weight: 500;
		color: var(--color-ink);
		line-height: 1.35;
		letter-spacing: -0.015em;
	}
	.row-desc {
		font-size: 0.92rem;
		color: var(--color-muted);
		line-height: 1.55;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.row-arrow {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		color: var(--color-muted-soft);
		transition: transform 200ms ease, color 160ms ease;
	}

	@media (max-width: 640px) {
		.post-row a {
			grid-template-columns: 100px 1fr;
			gap: 1rem;
			row-gap: 0.4rem;
			padding: 1.25rem 0.25rem;
		}
		.row-arrow {
			display: none;
		}
		.row-body {
			grid-column: 2 / 3;
		}
		.post-row a:hover {
			padding-left: 0.25rem;
		}
	}
</style>
