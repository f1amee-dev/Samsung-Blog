---
import Logo from '../assets/iza-razglednice.svg';
import HeaderLink from './HeaderLink.astro';
---

<div class="header-wrap">
	<header class="site-header">
		<a href="/" class="brand" aria-label="Iza Razglednice — naslovnica">
			<Logo width={26} height={24} class="brand-logo" aria-hidden="true" />
			<span class="brand-name">Iza Razglednice</span>
		</a>

		<nav class="nav" aria-label="Primary">
			<HeaderLink href="/">Naslovnica</HeaderLink>
			<HeaderLink href="/blog">Zapisi</HeaderLink>
			<HeaderLink href="/about">O projektu</HeaderLink>
		</nav>
	</header>
</div>

<style>
	.header-wrap {
		position: sticky;
		top: 0;
		z-index: 50;
		display: flex;
		justify-content: center;
		pointer-events: none;
	}

	.site-header {
		pointer-events: auto;
		display: inline-flex;
		align-items: center;
		gap: 1.75rem;
		padding: 0.55rem 0.9rem 0.55rem 0.85rem;
		background: color-mix(in srgb, var(--color-canvas) 88%, transparent);
		backdrop-filter: saturate(160%) blur(14px);
		-webkit-backdrop-filter: saturate(160%) blur(14px);
		border: 1px solid var(--color-rule);
		border-top: none;
		border-radius: 0 0 14px 14px;
		min-height: var(--header-height);
		box-shadow: 0 6px 20px -16px rgba(24, 50, 81, 0.18);
	}

	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.55rem;
		text-decoration: none;
		color: var(--color-brand);
		padding: 0.25rem 0.5rem 0.25rem 0.25rem;
		border-right: 1px solid var(--color-rule);
		transition: opacity 160ms ease;
	}
	.brand:hover {
		opacity: 0.75;
	}

	.brand-logo {
		width: 24px;
		height: auto;
		display: block;
		flex-shrink: 0;
	}

	.brand-name {
		font-family: var(--font-serif);
		font-weight: 400;
		font-size: 1.15rem;
		color: var(--color-brand);
		letter-spacing: -0.02em;
		line-height: 1;
		white-space: nowrap;
	}

	.nav {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		padding-right: 0.25rem;
	}

	@media (max-width: 640px) {
		.site-header {
			gap: 0.85rem;
			padding: 0.45rem 0.65rem 0.45rem 0.65rem;
			min-height: 52px;
			border-radius: 0 0 12px 12px;
		}
		.brand {
			padding-right: 0.65rem;
			gap: 0.45rem;
		}
		.brand-logo {
			width: 20px;
		}
		.brand-name {
			font-size: 1rem;
		}
		.nav {
			gap: 0.1rem;
		}
	}

	@media (max-width: 420px) {
		.brand-name {
			display: none;
		}
		.brand {
			border-right: none;
			padding-right: 0.25rem;
		}
	}
</style>
